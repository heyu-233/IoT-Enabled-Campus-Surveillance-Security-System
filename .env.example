# Application
SERVER_PORT=8081

# Spring Boot datasource
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/qgg_backend?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change-me

# JWT
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRATION=86400

# MQTT
MQTT_BROKER_URL=tcp://127.0.0.1:1883
MQTT_CLIENT_ID=backend-client
MQTT_USERNAME=
MQTT_PASSWORD=

# Detector supervisor
DETECTOR_SUPERVISOR_BASE_URL=http://127.0.0.1:19090
DETECTOR_RTMP_URL=rtmp://127.0.0.1:1935/myapp/stream
DETECTOR_MQTT_HOST=127.0.0.1
DETECTOR_MQTT_PORT=1883
DETECTOR_MODEL_PATH=best.pt
DETECTOR_DEVICE_ID=edge-node-001
DETECTOR_FPS=5
DETECTOR_RETRY_SECONDS=3
DETECTOR_JPEG_QUALITY=70
DETECTOR_DEDUPE_WINDOW_SECONDS=8
DETECTOR_DEDUPE_IOU_THRESHOLD=0.45

# Image storage
IMAGE_UPLOAD_PATH=./uploads/images
IMAGE_ACCESS_URL=/images
ALERT_AUTO_THRESHOLD=0.8

# Camera-side examples
RTMP_URL=rtmp://127.0.0.1:1935/myapp/stream
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
NET_CHECK_HOST=127.0.0.1
ETH_DEV=eth0
ETH_IP=192.0.2.2/24
